{
  "name": "trash-sorter-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3000",
    "dev:test": "next dev --hostname 127.0.0.1 --port 3100",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1 --port 3000",
    "start:test": "next start --hostname 127.0.0.1 --port 3100",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "audit": "node scripts/audit-web.mjs",
    "audit:smoke": "node scripts/audit-web.mjs --smoke",
    "audit:help": "node scripts/audit-web.mjs --help",
    "test:unit": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:unit:watch": "vitest --watch"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^0.468.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^2.1.9",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9"
  },
  "overrides": {
    "postcss": "^8.5.15"
  }
}
